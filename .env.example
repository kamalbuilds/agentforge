# ─────────────────────────────────────────────────────────────────────────────
# BLOCKCHAIN & NETWORKS
# ─────────────────────────────────────────────────────────────────────────────

# 0G Galileo testnet (primary deployment target)
ZG_RPC_URL=https://evmrpc-testnet.0g.ai
ZG_CHAIN_ID=16602
ZG_STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai

# 0G Compute provider endpoint
# Contact: 0G Labs Discord for provider URLs
ZG_COMPUTE_PROVIDER=

# Sepolia testnet (for cross-chain scenarios, optional)
SEPOLIA_RPC_URL=
ETHERSCAN_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# DEPLOYMENT & OPERATIONS
# ─────────────────────────────────────────────────────────────────────────────

# Private key for contract deployment (Galileo testnet)
# Faucet: https://faucet-testnet.0g.ai
DEPLOYER_PRIVATE_KEY=

# Private key for agent runtime operations (arena, breeding)
# Faucet: https://faucet-testnet.0g.ai
AGENT_OPERATOR_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# ENS CCIP-Read Gateway
# ─────────────────────────────────────────────────────────────────────────────

# ENS parent name for subname registrations (e.g., agentforge.eth)
ENS_PARENT_NAME=agentforge.eth

# Gateway URL for CCIP-Read responses (public endpoint)
# For local dev: use ngrok -> ngrok http 8787
# Then set to the ngrok HTTPS URL (e.g., https://abc-123.ngrok-free.app)
# For production: deploy gateway and set a stable URL here
ENS_GATEWAY_URL=

# Private key for CCIP-Read response signing (EIP-191)
# Used to sign subname resolution records
CCIP_SIGNER_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# AXL (Gensyn) - Agent P2P Messaging
# ─────────────────────────────────────────────────────────────────────────────

# Local AXL node URL (for agent-to-agent communication)
AXL_NODE_URL=http://localhost:9002

# Comma-separated peer addresses for mesh bootstrap
# Example: 0x123...,0x456...
AXL_PEERS=

# ─────────────────────────────────────────────────────────────────────────────
# KeeperHub - Automation
# ─────────────────────────────────────────────────────────────────────────────

# KeeperHub API key
# Sign up: https://keeperhub.com
KEEPERHUB_API_KEY=

# KeeperHub API endpoint
KEEPERHUB_API_URL=https://api.keeperhub.com

# ─────────────────────────────────────────────────────────────────────────────
# Uniswap Trade API
# ─────────────────────────────────────────────────────────────────────────────

# Uniswap Trade API key
# Sign up: https://uniswap.org/developers (requires API registration)
UNISWAP_API_KEY=

# Uniswap Trade API base URL
# Production: https://trade-api.gateway.uniswap.org/v1
# Testnet: Same endpoint, but only works with standard EVM testnets
UNISWAP_API_URL=https://trade-api.gateway.uniswap.org/v1
