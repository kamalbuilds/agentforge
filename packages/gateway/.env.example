# Server configuration
PORT=8787
NODE_ENV=development
LOG_LEVEL=info

# CCIP-Read signing key (must be a valid Ethereum private key without 0x prefix)
CCIP_SIGNER_KEY=your_private_key_here

# 0G Storage
ZEROG_INDEXER_URL=http://localhost:6000

# KeeperHub
KEEPERHUB_API_KEY=your_keeperhub_api_key
KEEPERHUB_BASE_URL=https://api.keeperhub.com

# Uniswap
UNISWAP_API_KEY=your_uniswap_api_key
UNISWAP_BASE_URL=https://trade-api.gateway.uniswap.org

# AXL Bridge
AXL_NODE_URL=http://localhost:5000

# RPC endpoints
RPC_URL_0G=https://evmrpc-testnet.0g.ai
RPC_URL_SEPOLIA=https://sepolia.infura.io/v3/YOUR_PROJECT_ID
